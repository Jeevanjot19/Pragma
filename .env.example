# Groq API Configuration
# PRIMARY API KEY - Your main Groq API key
GROQ_API_KEY=your_primary_groq_api_key_here

# BACKUP API KEY - Optional second Groq API key for failover
# If this is not set, the system will only use the primary API
# If set and the primary API fails (429 rate limit, timeout, etc.), 
# the system automatically switches to this backup key
GROQ_API_KEY_BACKUP=your_backup_groq_api_key_here

# Optional: Add more environment variables here as needed
# DATABASE_URL=sqlite:///pragma.db
